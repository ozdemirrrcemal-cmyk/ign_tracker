<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/gm_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="22dp"
            android:paddingTop="26dp"
            android:paddingRight="22dp"
            android:paddingBottom="28dp"
            android:background="@drawable/bg_toolbar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="14dp"
                android:paddingTop="7dp"
                android:paddingRight="14dp"
                android:paddingBottom="7dp"
                android:background="@drawable/bg_logo_badge"
                android:text="MIGROS"
                android:textColor="@color/migros_orange"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Güney Marmara"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kampanya Takip"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="26sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Mağaza kampanya uygulamalarını hızlı ve izlenebilir şekilde yönetin."
                android:textColor="#FFF4EA"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="22dp"
            android:paddingRight="18dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giriş"
                    android:textColor="@color/gm_text"
                    android:textStyle="bold"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mağaza kodu ve şifrenizle giriş yapın."
                    android:textColor="@color/gm_muted"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/inputLogin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:background="@drawable/bg_input"
                    android:hint="Mağaza kodu"
                    android:textColor="@color/gm_text"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:singleLine="true"
                    android:inputType="text" />

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:background="@drawable/bg_input"
                    android:hint="Şifre"
                    android:textColor="@color/gm_text"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:singleLine="true"
                    android:inputType="textPassword" />

                <TextView
                    android:id="@+id/tvLoginError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#B91C1C"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_orange_round"
                    android:text="Giriş Yap"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_soft_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kayıtlı mağaza"
                    android:textColor="@color/gm_text"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvStoreListPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/gm_muted"
                    android:textSize="13sp"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>