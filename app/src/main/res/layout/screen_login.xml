<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/gm_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingTop="28dp"
            android:paddingRight="20dp"
            android:paddingBottom="26dp"
            android:background="@drawable/bg_login_header">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingRight="10dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_logo_badge"
                android:text="MİGROS"
                android:textColor="@color/migros_orange"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Güney Marmara Kampanya Takip"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mağaza kampanya uygulamalarını sade, hızlı ve izlenebilir şekilde yönetin."
                android:textColor="#FFF4EA"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_card"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giriş"
                    android:textColor="@color/gm_text"
                    android:textStyle="bold"
                    android:textSize="19sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mağaza kodu ve şifrenizle giriş yapın. Yönetici hesabı için admin e-posta adresi kullanılabilir."
                    android:textColor="@color/gm_muted"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/inputLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input"
                    android:hint="Mağaza kodu / admin e-posta"
                    android:singleLine="true"
                    android:inputType="text"
                    android:textColor="@color/gm_text"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/inputPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="Şifre"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:textColor="@color/gm_text"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvLoginError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/gm_danger"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_orange_round"
                    android:text="Giriş Yap"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/bg_soft_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kayıtlı mağaza listesi"
                    android:textColor="@color/gm_text"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvStoreListPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="8876 • Aziziye Mahallesi MM Migros"
                    android:textColor="@color/gm_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
